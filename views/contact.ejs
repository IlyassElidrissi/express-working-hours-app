<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact Us - Working Hours App</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <div class="hero">
      <h1>Contact Us</h1>
      <p>We'd love to hear from you. Get in touch with our team.</p>
    </div>

    <div class="content">
      <h2>Get in Touch</h2>
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem;">
        <div>
          <h3>Our Contact Information</h3>
          <p>
            <strong>📧 Email:</strong><br>
            info@workinghoursapp.com<br>
            support@workinghoursapp.com
          </p>
          <p>
            <strong>📞 Phone:</strong><br>
            +1 (555) 123-4567<br>
            +1 (555) 987-6543
          </p>
          <p>
            <strong>📍 Address:</strong><br>
            123 Business Street<br>
            Suite 400<br>
            New York, NY 10001<br>
            USA
          </p>
          <p>
            <strong>🕐 Office Hours:</strong><br>
            Monday - Friday<br>
            9:00 AM - 5:00 PM<br>
            (UTC-5)
          </p>
        </div>

        <div>
          <h3>Social Media</h3>
          <p style="line-height: 2;">
            <strong>Follow us on:</strong><br>
            🔗 <a href="#" style="color: #667eea; text-decoration: none;">LinkedIn</a><br>
            🔗 <a href="#" style="color: #667eea; text-decoration: none;">Twitter</a><br>
            🔗 <a href="#" style="color: #667eea; text-decoration: none;">Facebook</a><br>
            🔗 <a href="#" style="color: #667eea; text-decoration: none;">Instagram</a>
          </p>
        </div>
      </div>

      <h3>Send us a Message</h3>
      <form class="contact-form" action="#" method="POST">
        <div class="form-group">
          <label for="name">Your Name</label>
          <input type="text" id="name" name="name" required placeholder="John Doe">
        </div>

        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required placeholder="john@example.com">
        </div>

        <div class="form-group">
          <label for="phone">Phone Number</label>
          <input type="tel" id="phone" name="phone" placeholder="+1 (555) 123-4567">
        </div>

        <div class="form-group">
          <label for="subject">Subject</label>
          <input type="text" id="subject" name="subject" required placeholder="How can we help you?">
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" required placeholder="Tell us more about your inquiry..."></textarea>
        </div>

        <button type="submit">Send Message</button>
      </form>
    </div>
  </div>

  <footer>
    <p>&copy; 2024 Working Hours App. All rights reserved.</p>
  </footer>
</body>
</html>
